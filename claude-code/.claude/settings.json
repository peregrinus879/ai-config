{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(du *)",
      "Bash(file *)",
      "Bash(find)",
      "Bash(find *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(stat *)",
      "Bash(tree)",
      "Bash(tree *)",
      "Bash(wc *)",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(* > *)",
      "Bash(* >> *)",
      "Bash(* | tee*)",
      "Bash(find * -delete*)",
      "Bash(find * -exec *)",
      "Bash(find * -execdir *)",
      "Bash(find * -ok *)",
      "Bash(find * -okdir *)",
      "Bash(tree * --output *)",
      "Bash(tree * -o *)",
      "Read(./**/*.key)",
      "Read(./**/*.pem)",
      "Read(./**/*credentials*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(~/.aws/credentials)",
      "Read(~/.gnupg/**)",
      "Read(~/.ssh/**)"
    ]
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "effortLevel": "high",
  "autoUpdatesChannel": "stable"
}
