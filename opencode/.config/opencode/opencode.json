{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "autoupdate": true,
  "model": "openai/gpt-5.5",
  "agent": {
    "build": {
      "permission": {
        "bash": {
          "*": "ask",
          "git branch": "allow",
          "git branch --show-current": "allow",
          "git diff": "allow",
          "git diff *": "allow",
          "git log": "allow",
          "git log *": "allow",
          "git rev-parse --abbrev-ref @{upstream}": "allow",
          "git rev-parse --abbrev-ref HEAD": "allow",
          "git show": "allow",
          "git show *": "allow",
          "git status": "allow",
          "git status *": "allow",
          "ls": "allow",
          "ls *": "allow",
          "pwd": "allow"
        },
        "edit": "ask"
      }
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        "gemma4:31b": {
          "name": "gemma4:31b"
        }
      }
    },
    "openai": {
      "models": {
        "gpt-5.5": {
          "options": {
            "reasoningEffort": "xhigh"
          }
        }
      }
    }
  },
  "instructions": [
    "{env:HOME}/.claude/rules/shared-guidance.md"
  ]
}
