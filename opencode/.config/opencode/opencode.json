{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "{env:HOME}/.claude/rules/shared-guidance.md"
  ],
  "model": "openai/gpt-5.4",
  "default_agent": "plan",
  "agent": {
    "build": {
      "permission": {
        "bash": {
          "*": "ask",
          "git branch": "allow",
          "git branch --show-current": "allow",
          "git diff": "allow",
          "git diff *": "allow",
          "git log": "allow",
          "git log *": "allow",
          "git rev-parse --abbrev-ref @{upstream}": "allow",
          "git rev-parse --abbrev-ref HEAD": "allow",
          "git show": "allow",
          "git show *": "allow",
          "git status": "allow",
          "git status *": "allow",
          "ls": "allow",
          "ls *": "allow",
          "pwd": "allow"
        },
        "edit": "ask"
      }
    }
  },
  "autoupdate": true,
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "**/*.key": "deny",
      "**/*.pem": "deny",
      "**/*credentials*": "deny",
      "**/secrets/**": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "~/.aws/credentials": "deny",
      "~/.gnupg/**": "deny",
      "~/.ssh/**": "deny"
    },
    "glob": "allow",
    "grep": "allow",
    "lsp": "allow",
    "question": "allow",
    "edit": "deny",
    "bash": {
      "*": "ask",
      "du *": "allow",
      "file *": "allow",
      "find": "allow",
      "find *": "allow",
      "ls": "allow",
      "ls *": "allow",
      "stat *": "allow",
      "tree": "allow",
      "tree *": "allow",
      "wc *": "allow",
      "* > *": "deny",
      "* >> *": "deny",
      "* | tee*": "deny",
      "find * -delete*": "deny",
      "find * -exec *": "deny",
      "find * -execdir *": "deny",
      "find * -ok *": "deny",
      "find * -okdir *": "deny",
      "tree * --output *": "deny",
      "tree * -o *": "deny"
    },
    "webfetch": "allow",
    "websearch": "allow",
    "external_directory": "ask"
  },
  "share": "disabled",
  "provider": {
    "ollama": {
      "models": {
        "gemma4:31b": {
          "name": "gemma4:31b"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    },
    "openai": {
      "models": {
        "gpt-5.4": {
          "options": {
            "reasoningEffort": "xhigh"
          }
        }
      }
    }
  }
}
